        @* /* =========================================================================
           /* === CONTENIDO PRINCIPAL (DERECHA) ===
              Incluye:
                - topbar (barra superior)
                - main (RenderBody)
                - footer
           ========================================================================= */ *@

        <div class="sidebar-overlay"></div>

        <div class="app-content">

            @* /* =====================================================================
               /* === TOPBAR (BARRA SUPERIOR) ===
                  IZQUIERDA:
                    - botón toggle sidebar
                    - switch modo oscuro
                  DERECHA:
                    - mensaje de bienvenida
                    - login/logout
               ===================================================================== */ *@
            <header class="topbar">

                @* /* === IZQUIERDA: ACCIONES DE UI === */ *@
                <div class="topbar-left">

                    @* /* === TOGGLE MENÚ LATERAL === */ *@
                    <button type="button" class="btn-sidebar-toggle" aria-label="Abrir/Cerrar menú">
                        <i class="bx bx-menu" aria-hidden="true"></i>
                    </button>

                    @* /* === DARK MODE (UI) === */ *@

                    <!-- === BOTÓN DARK MODE SIMPLE === -->
                    <button type="button" class="btn-theme-toggle" aria-label="Cambiar modo">
                        <i class="bx bx-moon theme-icon"></i>
                    </button>

                </div>

                @* /* === DERECHA: AUTENTICACIÓN / SESIÓN === */ *@
                <div class="topbar-right">

                    @if (User?.Identity?.IsAuthenticated == true)
                    {
                        @* /* === USUARIO AUTENTICADO === */ *@
                        <span class="welcome">
                            Bienvenido, <strong>@User.Identity!.Name</strong>
                        </span>

                        @* /* === LOGOUT (POST) === */ *@
                        <form asp-controller="Account" asp-action="Logout" method="post" class="d-inline">
                            <button type="submit" class="btn-topbar">
                                <i class="bx bx-log-out" aria-hidden="true"></i>
                                Cerrar sesión
                            </button>
                        </form>
                    }
                    else
                    {
                        @* /* === USUARIO NO AUTENTICADO === */ *@
                        <span class="welcome">Bienvenido</span>

                        @* /* === LOGIN (GET) === */ *@
                        <a asp-controller="Account" asp-action="Login" class="btn-topbar">
                            <i class="bx bx-log-in" aria-hidden="true"></i>
                            Iniciar sesión
                        </a>
                    }

                </div>
            </header>

            @* /* =====================================================================
               /* === MAIN (CONTENIDO POR VISTA) ===
                  Aquí se renderiza el contenido de cada Controller/Action:
                    - Index / Create / Edit / Details, etc.
               ===================================================================== */ *@
            <main class="main-area">
                <div class="content-container">
                    @RenderBody()
                </div>
            </main>

            @* /* =====================================================================
               /* === FOOTER ===
               ===================================================================== */ *@
            <footer class="border-top text-muted py-2">
                <div class="container">
                    &copy; 2026 - CMAP Dep. Sistemas
                </div>
            </footer>

        </div>
    </div>

    @* /* =========================================================================
       /* === SCRIPTS GLOBALES ===
          Recomendación: scripts al final para mejor performance.
       ========================================================================= */ *@
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    
    @* /* =========================================================================
       /* === SECCIÓN OPCIONAL: SCRIPTS POR VISTA ===
          Ejemplo en una vista:
            @section Scripts { <script>...</script> }
       ========================================================================= */ *@
    @await RenderSectionAsync("Scripts", required: false)

</body>
</html>
