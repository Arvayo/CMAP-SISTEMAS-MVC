@* ============================================================================
     DESCRIPCIÓN:
     Layout base del sistema.
     Contiene:
       - HEAD (meta, título, estilos)
       - APP SHELL (sidebar + contenido)
       - SIDEBAR (menú lateral)
       - TOPBAR (barra superior: toggle + modo + login/logout)
       - MAIN (RenderBody)
       - FOOTER
       - SCRIPTS (bootstrap, site.js, JS inline + RenderSection Scripts)

   NOTAS DE MANTENIMIENTO:
     1) Mantén en el layout solo estructura global.
     2) Si el menú crece más, conviene volverlo dinámico (lista en C# / Partial / ViewComponent).
     3) La lógica JS (toggle sidebar/submenús/dark mode) idealmente debe vivir en /wwwroot/js/site.js
   ============================================================================ *@

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - CMAP_SISTEMAS_MVC</title>
    <script type="importmap"></script>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/CMAP_SISTEMAS_MVC.styles.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link href="https://unpkg.com/boxicons@2.1.4/css/boxicons.min.css" rel="stylesheet">
</head>


<body class="min-vh-100">

    @* /* =========================================================================
       /* === APP SHELL (CONTENEDOR GENERAL) ===
          Estructura principal:
            - nav.menu-lateral   (sidebar)
            - div.app-content    (contenido)
       ========================================================================= */ *@
    <div class="app-shell">

        @* /* =========================================================================
           /* === MENU LATERAL (SIDEBAR) ===
              - Clase base: .menu-lateral
              - Estado colapsado: .close  (JS la alterna)
              - Elementos con submenú: li.has-submenu
              - Submenú abierto: .open     (JS la alterna)
           ========================================================================= */ *@
        <nav class="menu-lateral" aria-label="Menú lateral">

            @* /* === HEADER DEL MENÚ / LOGO === */ *@
            <header>
