@model CMAP_SISTEMAS_MVC.Models.ViewModels.SociosIndexVM

@{
    ViewData["Title"] = "Socios";
}

<h2>Socios</h2>

@if (!string.IsNullOrWhiteSpace(Model?.Mensaje))
{
    var clase = Model.TipoMensaje == "success"
        ? "alert alert-success"
        : "alert alert-danger";

    var icono = Model.TipoMensaje == "success"
        ? "✔"
        : "✖";

    <div class="@clase mt-3">
        <strong>@icono</strong> @Model.Mensaje
    </div>
}

<form asp-controller="Socios" asp-action="Index" method="post" class="mt-3">
    @Html.AntiForgeryToken()

    <div class="row g-3 align-items-end">
        <div class="col-12 col-md-4">
            <label asp-for="ClavePension" class="form-label">Pension</label>
            <input asp-for="ClavePension" class="form-control" maxlength="10" autocomplete="off" />
        </div>

        <div class="col-12 col-md-3">
            <label asp-for="Nombre" class="form-label">Nombre</label>
            <input asp-for="Nombre" class="form-control" autocomplete="off" />
        </div>

        <div class="col-12 col-md-3">
            <label asp-for="Apellidos" class="form-label">Apellidos</label>
            <input asp-for="Apellidos" class="form-control" autocomplete="off" />
        </div>

        <div class="col-12 col-md-2 d-grid">
            <button type="submit" class="btn btn-search">
                Buscar
            </button>
        </div>
    </div>
</form>


@if (Model?.Socio != null)
{
    <div class="card mt-3">
        <div class="card-header">
            Resultado
        </div>
        <div class="card-body">
            <div class="row g-4">

                <!-- Columna izquierda -->
                <div class="col-12 col-lg-4">
                    <h6 class="text-muted mb-2">Identificación</h6>
                    <div><b>Pension:</b> @Model.Socio.ClavePension</div>
                    <div><b>Nombre:</b> @Model.Socio.NombreSocio @Model.Socio.ApellidosSocio</div>
                    <div><b>Fecha de Nacimiento:</b> @Model.Socio.FECHANAC?.ToString("dd/MM/yyyy")</div>
                    <div><b>Lugar de Nacimiento:</b> @Model.Socio.LugarNac</div>
                    <div><b>Estado de Nacimiento:</b> @Model.Socio.EdoNac</div>
                    <div><b>Sexo:</b> @Model.Socio.SEXO</div>
                    <div><b>Estado Civil:</b> @Model.Socio.EDOCIVIL</div>
                    <div><b>Estatus:</b> @Model.Socio.EstatusActualSocio</div>
                    <div><b>RFC:</b> @Model.Socio.RFC</div>
                    <div><b>CURP:</b> @Model.Socio.CURP</div>

                    <!-- ========================= -->
                    <!--      CMAP CONTROL         -->
                    <!-- ========================= -->
                    <h6 class="text-muted mt-4 mb-2">CMAP Control</h6>

                    <div><b>Vigencia:</b> @Model.Socio.VIGENCIA</div>
                    <div><b>Situacion:</b> @Model.Socio.SITUACION</div>
                    <div><b>FechaAltaActivo:</b> @Model.Socio.FechaAltaActivo?.ToString("dd/MM/yyyy")</div>
                    <div><b>FechaAltaJub/Pen:</b> @Model.Socio.FechaAltaJubiladoPen?.ToString("dd/MM/yyyy")</div>
                    <div><b>FechaBaja:</b> @Model.Socio.FechaBaja?.ToString("dd/MM/yyyy")</div>
                    <div><b>TipoPension:</b> @Model.Socio.TIPOPENSION</div>
                    <div><b>PensionAnterior:</b> @Model.Socio.PENSIONANT</div>
                    <div><b>Ubicacion:</b> @Model.Socio.UBICA</div>
                    <div><b>Reviso:</b> @Model.Socio.REVISO</div>
                    <div><b>CT:</b> @Model.Socio.CT</div>
                    <div><b>FechaCedula:</b> @Model.Socio.FECHACEDULA?.ToString("dd/MM/yyyy")</div>
                    <div><b>RECCEDULA:</b> @Model.Socio.RECCEDULA</div>
                    <div><b>FechaCMAP:</b> @Model.Socio.FECHACMAP?.ToString("dd/MM/yyyy")</div>
                    <div><b>AVISO:</b> @Model.Socio.AVISO</div>
                    <div><b>TUTOR:</b> @Model.Socio.TUTOR</div>
                    <div><b>COTIZANDO:</b> @Model.Socio.COTIZANDO</div>
                    <div><b>SOLICITA:</b> @Model.Socio.SOLICITA</div>
                    <div><b>ADSCRIPCION:</b> @Model.Socio.ADSCRIPCION</div>
                    <div><b>CONTRASENIA:</b> @Model.Socio.CONTRASENIA</div>
                    <div><b>FECULTAC:</b> @Model.Socio.FECULTAC</div>
                    <div><b>CONDONACION:</b> @Model.Socio.CONDONACION</div>
                    <div><b>NIVPRIV:</b> @Model.Socio.NIVPRIV</div>
                    <div><b>CuentaDebito:</b> @Model.Socio.CuentaDebito</div>
                    <div><b>AH50:</b> @Model.Socio.AH50</div>
                    <div><b>FECHAAH50:</b> @Model.Socio.FECHAAH50?.ToString("dd/MM/yyyy")</div>
                    <div><b>AG:</b> @Model.Socio.AG</div>

                </div>

                <!-- Columna centro -->
                <div class="col-12 col-lg-4">
                    <h6 class="text-muted mb-2">Contacto</h6>
                    <div><b>Teléfono:</b> @Model.Socio.TelefonoSocio</div>
                    <div><b>Celular:</b> @Model.Socio.TELCELULAR</div>
                    <div><b>Email:</b> @Model.Socio.EMAIL</div>

                    <h6 class="text-muted mt-3 mb-2">Dirección</h6>
                    <div><b>Calle:</b> @Model.Socio.DireccionSocio</div>
                    <div><b>Colonia:</b> @Model.Socio.COLONIA</div>
                    <div><b>Ciudad:</b> @Model.Socio.CiudadSocio</div>
                    <div><b>CP:</b> @Model.Socio.CP</div>

                    <!-- ========================= -->
                    <!--   OBSERVACIONES           -->
                    <!-- ========================= -->
                    <div class="mt-3">
                        <h6 class="text-muted mb-2">Observaciones</h6>
                        <textarea class="form-control" rows="5" readonly>@Model.Socio.OBS</textarea>
                    </div>

                    <!-- ========================= -->
                    <!--   CREDITOS           -->
                    <!-- ========================= -->
                    <div class="mt-3">
                        <h6 class="text-muted mb-2">Creditos</h6>
                        <div><b>TOTSUELDONOMINA:</b> @Model.Socio.TOTSUELDONOMINA</div>
                        <div><b>Sueldo Neto:</b> @Model.Socio.SueldoNetoTotal</div>
                        <div><b>SDOAHORROSINICIAL:</b> @Model.Socio.SDOAHORROSINICIAL</div>
                        <div><b>Ahorros:</b> @Model.Socio.SaldoAhorros</div>
                        <div><b>SDOPRESTAMOSINI:</b> @Model.Socio.SDOPRESTAMOSINI</div>
                        <div><b>Préstamos:</b> @Model.Socio.SaldoPrestamos</div>
                        <div><b>EnvioDescuentos:</b> @Model.Socio.EnvioDesctos</div>
                        <div><b>SueldoParaDescuentos:</b> @Model.Socio.SueldoParaDescuentos</div>
                        <div><b>IMPREMANENTE:</b> @Model.Socio.IMPREMANENTE</div>
                        <div><b>ULTNOMINA:</b> @Model.Socio.ULTNOMINA</div>
                        <div><b>ULTAPORTA:</b> @Model.Socio.ULTAPORTA</div>
                        <div><b>SDOINVER:</b> @Model.Socio.SDOINVER</div>
                        <div><b>SDOINVERINI:</b> @Model.Socio.SDOINVERINI</div>
                        
                    </div>
                </div>

                <!-- Columna derecha -->
                <!-- ========================= -->
                <!--   DATOS GENERALES           -->
                <!-- ========================= -->
                 <div class="col 12 col-lg-4"> 
                    <div class="mt-3">
                       <h6 class="text-muted mb-2">Datos Generales</h6>
                        <div><b>CLABE:</b> @Model.Socio.CLABE</div>
                        <div><b>ClaveSuc:</b> @Model.Socio.ClaveSuc</div>
                        <div><b>REGION:</b> @Model.Socio.REGION</div>
                        <div><b>FOLIO:</b> @Model.Socio.FOLIO</div>
                        <div><b>ARCHIVO:</b> @Model.Socio.ARCHIVO</div>
                        <div><b>DELEGACION:</b> @Model.Socio.DELEGACION</div>
                        <div><b>FOLIOCEDULA:</b> @Model.Socio.FOLIOCEDULA</div>
                        <div><b>BECARIO:</b> @Model.Socio.BECARIO</div>
                        <div><b>CatSocio:</b> @Model.Socio.CatSocio</div>
                        <div><b>EstatusActualSocio:</b> @Model.Socio.EstatusActualSocio</div>
                        <div><b>EmpleadoSindicato:</b> @Model.Socio.EmpleadoSindicato</div>

                    <div class="mt-3">
                      <h6 class="text-muted mb-2">Asistencia Social</h6>
                        <div><b>PorceJub:</b> @Model.Socio.PorceJub</div>
                        <div><b>RECIBENIVELACION:</b> @Model.Socio.RECIBENIVELACION</div>
                        <div><b>AportaSindi:</b> @Model.Socio.AportaSindi</div>
                        <div><b>MontoAportaSindi:</b> @Model.Socio.MontoAportaSindi</div>
                        <div><b>ACUFORE:</b> @Model.Socio.ACUFORE</div>
                        <div><b>PORCEFORE:</b> @Model.Socio.PORCEFORE</div>
                        <div><b>SALDOFORE:</b> @Model.Socio.SALDOFORE</div>
                        <div><b>SDOFOREINICIAL:</b> @Model.Socio.SDOFOREINICIAL</div>
                        <div><b>SaldoFide:</b> @Model.Socio.SaldoFide</div>
                        <div><b>SDOFIDEINICIAL:</b> @Model.Socio.SDOFIDEINICIAL</div>
                        <div><b>FIDEPROYECTADO:</b> @Model.Socio.FIDEPROYECTADO</div>
                        <div><b>CTADEP_NIV:</b> @Model.Socio.CTADEP_NIV</div>
                       
                    </div>
                </div>
            </div>
                

            </div>
        </div>
    </div>
}
@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}